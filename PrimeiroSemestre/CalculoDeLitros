#include <stdio.h>
int main() {
float dist, L, temp, velo;
printf("--------------------------\n");
printf("CALCULAR LITROS UTILIZADOS\n");
printf("--------------------------\n");
printf("\n");
printf("Digite a duração (horas) da viagem: ");
scanf("%f", &temp);
printf("Digite a velocidade média (km/h) durante a viagem: ");
scanf("%f", &velo);
dist = temp * velo;
L = dist/12;
printf("\n");
printf("Velocidade média: %.2f km/h\n", velo);
printf("Duração: %.2f horas\n", temp);
printf("Distância: %.2f km\n", dist);
printf("Litros: %.2f L\n", L);
}
